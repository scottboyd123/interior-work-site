<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }}</title>
<meta name="description" content="{{ description }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,400;1,9..144,500&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --paper:#F2EEE4; --paper-deep:#E7E0CE; --ink:#2B2A28; --ink-soft:#57534C;
    --moss:#3D4A3B; --moss-deep:#2A342A; --moss-text:#E9E7DA;
    --gold:#AD8A50; --gold-bright:#C6A567; --taupe:#8C7A6B;
    --line: rgba(43,42,40,0.14); --line-on-moss: rgba(233,231,218,0.22);
  }
  *{box-sizing:border-box;}
  html{scroll-behavior:smooth;}
  body{margin:0;background:var(--paper);color:var(--ink);font-family:'Inter',sans-serif;font-size:17px;line-height:1.65;-webkit-font-smoothing:antialiased;}
  h1,h2,h3,.display{font-family:'Fraunces',serif;font-weight:500;letter-spacing:-0.01em;margin:0;}
  .mono{font-family:'IBM Plex Mono',monospace;letter-spacing:0.04em;text-transform:uppercase;font-size:12.5px;}
  a{color:inherit;} img{max-width:100%;display:block;}
  .wrap{max-width:1200px;margin:0 auto;padding:0 32px;}
  .narrow{max-width:840px;}
  header{position:sticky;top:0;z-index:50;background:rgba(242,238,228,0.88);backdrop-filter:blur(8px);border-bottom:1px solid var(--line);}
  .nav-inner{max-width:1200px;margin:0 auto;padding:18px 32px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;}
  .brand{font-family:'Fraunces',serif;font-size:19px;font-weight:600;text-decoration:none;color:var(--ink);}
  .nav-links{display:flex;gap:28px;align-items:center;font-size:13px;}
  .nav-links a{text-decoration:none;color:var(--ink-soft);border-bottom:1px solid transparent;transition:border-color .2s, color .2s;}
  .nav-links a:hover{color:var(--ink);border-color:var(--gold);}
  .nav-links .cta{color:var(--ink);border:1px solid var(--ink);padding:8px 16px;border-radius:2px;}
  .nav-links .cta:hover{background:var(--ink);color:var(--paper);}
  .hero{position:relative;min-height:88vh;display:flex;align-items:flex-end;overflow:hidden;}
  .hero-bg{position:absolute;inset:0;background-image:url('/images/hero-forest.jpg');background-size:cover;background-position:center 40%;}
  .hero-scrim{position:absolute;inset:0;background:linear-gradient(180deg, rgba(20,22,18,0.15) 0%, rgba(20,22,18,0.35) 55%, rgba(20,22,18,0.78) 100%);}
  .hero-content{position:relative;z-index:2;width:100%;padding:0 32px 32px;max-width:1200px;margin:0 auto;color:var(--moss-text);}
  .hero-logo{margin-bottom:32px;}
  .hero-logo img{width:min(560px, 70vw);height:auto;object-fit:contain;filter:drop-shadow(0 2px 10px rgba(0,0,0,0.55)) drop-shadow(0 0 22px rgba(0,0,0,0.35));}
  .eyebrow{color:var(--gold-bright);margin-bottom:14px;display:flex;align-items:center;gap:10px;}
  .eyebrow::before{content:"";width:26px;height:1px;background:var(--gold-bright);display:inline-block;}
  h1.name{font-family:'Inter',sans-serif;font-weight:600;letter-spacing:-0.02em;font-size:clamp(38px,5.6vw,60px);line-height:1.05;color:#fff;}
  .credentials{font-family:'Inter',sans-serif;margin-top:14px;color:rgba(233,231,218,0.85);}
  .credentials div{margin-top:4px;}
  .hero-desc{margin-top:22px;font-size:17px;color:rgba(233,231,218,0.9);max-width:60ch;}
  .hero-actions{margin-top:30px;display:flex;gap:18px;flex-wrap:wrap;align-items:center;}
  .btn-primary{background:var(--gold-bright);color:#211d14;padding:14px 26px;border-radius:2px;text-decoration:none;font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:0.06em;text-transform:uppercase;transition:background .2s;display:inline-block;}
  .btn-primary:hover{background:#d8b878;}
  .hero-contact{font-size:13.5px;color:rgba(233,231,218,0.85);}
  .hero-contact a{text-decoration:none;border-bottom:1px solid rgba(233,231,218,0.4);}
  .page-header{background:var(--moss);color:var(--moss-text);padding:56px 0 44px;}
  .page-header h1{font-size:clamp(30px,4vw,42px);color:#fff;}
  .page-header p{margin-top:14px;color:rgba(233,231,218,0.85);max-width:60ch;}
  .pause{background:var(--moss);color:var(--moss-text);padding:44px 0;position:relative;}
  .pause-inner{max-width:900px;margin:0 auto;padding:0 32px;text-align:center;}
  .pause blockquote{font-family:'Inter',sans-serif;font-style:normal;font-weight:400;font-size:clamp(20px,2.6vw,26px);line-height:1.55;margin:0;opacity:0;transform:translateY(14px);transition:opacity 1s ease, transform 1s ease;}
  .pause.in-view blockquote{opacity:1;transform:translateY(0);}
  .pause cite{display:block;margin-top:26px;font-style:normal;color:var(--gold-bright);font-size:16px;letter-spacing:0.06em;}
  .pause .mark{width:1px;height:34px;background:var(--line-on-moss);margin:0 auto 26px;}
  section.prose{padding:48px 0;}
  section.prose h2{font-size:clamp(24px,3.6vw,38px);line-height:1.15;margin-bottom:6px;}
  section.prose h3.subtitle{font-family:'Fraunces',serif;font-style:italic;font-weight:400;color:var(--taupe);font-size:19px;margin-top:8px;margin-bottom:16px;}
  section.prose p{color:var(--ink-soft);margin:0 0 16px;}
  section.prose p strong{color:var(--ink);font-weight:600;}
  hr.rule{border:none;border-top:1px solid var(--line);margin:0;}
  .about-grid{display:grid;grid-template-columns:1fr 1.35fr;gap:64px;align-items:start;}
  .about-photo{border-radius:2px;overflow:hidden;}
  .kv-list{margin-top:22px;}
  .kv-list .row{display:flex;gap:18px;padding:14px 0;border-top:1px solid var(--line);}
  .kv-list .row:last-child{border-bottom:1px solid var(--line);}
  .kv-list .k{width:150px;flex-shrink:0;color:var(--taupe);}
  .kv-list .v{color:var(--ink-soft);}
  .kv-list .v a{color:var(--ink);text-decoration:none;border-bottom:1px solid var(--line);}
  .assoc-list{margin-top:8px;color:var(--ink-soft);font-size:15px;}
  .assoc-list li{margin-bottom:6px;}
  .modality{display:grid;grid-template-columns:220px 1fr;gap:40px;padding:20px 0;border-top:1px solid var(--line);}
  .modality:last-of-type{border-bottom:1px solid var(--line);}
  .modality h3{font-size:22px;}
  .modality p{color:var(--ink-soft);margin:0 0 12px;}
  .modality a{font-size:13px;text-decoration:none;color:var(--ink);border-bottom:1px solid var(--gold);}
  .split{display:grid;grid-template-columns:1fr 1fr;gap:64px;}
  .taglist{list-style:none;margin:18px 0 0;padding:0;display:flex;flex-wrap:wrap;gap:10px;}
  .taglist li{border:1px solid var(--line);padding:9px 16px;border-radius:2px;font-family:'IBM Plex Mono',monospace;font-size:12.5px;letter-spacing:0.04em;text-transform:uppercase;color:var(--ink-soft);}
  .rates-card{background:var(--paper-deep);border-radius:2px;padding:24px;}
  .contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center;}
  .contact-photo{border-radius:2px;overflow:hidden;}
  .contact-photo figcaption{margin-top:8px;color:var(--taupe);font-size:13px;}
  .contact-lines{color:var(--ink-soft);margin:20px 0 30px;}
  .contact-lines div{margin-bottom:4px;}
  .contact-lines a{color:var(--ink);text-decoration:none;border-bottom:1px solid var(--line);}
  .crisis-list .row{padding:20px 0;border-top:1px solid var(--line);}
  .crisis-list .row:last-child{border-bottom:1px solid var(--line);}
  .crisis-list .row strong{display:block;margin-bottom:6px;color:var(--ink);}
  .crisis-list .row p{margin:0;color:var(--ink-soft);}
  .crisis-911{background:var(--paper-deep);padding:20px 24px;border-radius:2px;margin-bottom:8px;}
  .book-grid{display:grid;grid-template-columns:repeat(auto-fill, minmax(140px, 1fr));gap:22px;}
  .book-grid a{display:block;text-decoration:none;}
  .book-cover{aspect-ratio:2/3;border-radius:2px;overflow:hidden;background:var(--paper-deep);box-shadow:0 6px 18px rgba(43,42,40,0.12);transition:transform .2s ease;}
  .book-cover img{width:100%;height:100%;object-fit:cover;}
  .book-grid a:hover .book-cover{transform:translateY(-4px);}
  .disclaimer{background:var(--paper-deep);border-radius:2px;padding:28px;color:var(--ink-soft);font-size:14.5px;}
  .grounding-img{border-radius:2px;overflow:hidden;margin-top:8px;}
  .change-triangle-quote{border-left:2px solid var(--gold);padding-left:24px;margin:24px 0;color:var(--ink-soft);font-size:17px;line-height:1.6;}
  .vagal-list .row{padding:16px 0;border-top:1px solid var(--line);}
  .vagal-list .row:last-child{border-bottom:1px solid var(--line);}
  .vagal-list .row strong{color:var(--ink);}
  .vagal-list .row p{margin:4px 0 0;color:var(--ink-soft);}
  footer{background:var(--moss-deep);color:var(--moss-text);padding:22px 0;font-size:13px;}
  .footer-inner{max-width:1200px;margin:0 auto;padding:0 32px;display:flex;justify-content:space-between;flex-wrap:wrap;gap:12px;color:rgba(233,231,218,0.62);}
  .footer-inner a{color:rgba(233,231,218,0.8);text-decoration:none;}
  @media (max-width:820px){
    .about-grid,.split,.contact-grid{grid-template-columns:1fr;}
    .modality{grid-template-columns:1fr;gap:10px;}
    .nav-links{font-size:12px;gap:16px;}
    .rates-card{padding:24px;}
    .hero{min-height:80vh;}
    .book-grid{grid-template-columns:repeat(auto-fill, minmax(110px, 1fr));gap:16px;}
  }
  @media (prefers-reduced-motion:reduce){html{scroll-behavior:auto;} .pause blockquote{transition:none;opacity:1;transform:none;}}
  :focus-visible{outline:2px solid var(--gold);outline-offset:2px;}
</style>
</head>
<body>

<header>
  <div class="nav-inner">
    <a class="brand" href="/">Scott Boyd, LPC, LAC</a>
    <nav class="nav-links">
      <a href="mailto:{{ home.email }}">Email Me</a>
      <a href="tel:{{ home.phone_link }}">{{ home.phone }}</a>
      <a href="/reading-list/">Resources</a>
      <a class="cta" href="{{ home.booking_url }}">Request a Free Consult</a>
    </nav>
  </div>
</header>

{{ content | safe }}

<footer>
  <div class="footer-inner">
    <div>{{ home.address_line1 }}, {{ home.address_line2 }} — <a href="tel:{{ home.phone_link }}">{{ home.phone }}</a> — <a href="mailto:{{ home.email }}">{{ home.email }}</a></div>
  </div>
  <div class="footer-inner" style="margin-top:14px;">
    <div>Scott Boyd, MA, LPC, LAC | {{ home.address_line1 }} | {{ home.phone }}</div>
  </div>
</footer>

<script>
  const pauses = document.querySelectorAll('[data-pause]');
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting) e.target.classList.add('in-view'); });
  }, {threshold:0.35});
  pauses.forEach(p=>io.observe(p));
</script>
</body>
</html>
